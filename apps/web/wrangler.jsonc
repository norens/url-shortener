    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_VCzsZgkPGwEoQjE-CkM5ww_n6Kpqvic",
    "NEXT_PUBLIC_API_URL": "https://api.qurl.nazarf.dev",
    "NEXT_PUBLIC_CONTACT_EMAIL": "qurl@nazarf.dev"
  }
}
